{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://swarmcp.dev/schemas/swarmcp-project.v1.schema.json",
  "title": "SwarmCP Project",
  "description": "Schema for SwarmCP project.yaml files. This schema is optimized for editor completion and basic shape validation; swarmcp validate remains the source of truth for semantic validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["project"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema URI for editors that support the standard $schema key."
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "stacks": {
      "type": "object",
      "description": "Logical stack definitions keyed by stack name.",
      "additionalProperties": {
        "$ref": "#/$defs/stack"
      }
    },
    "overlays": {
      "$ref": "#/$defs/overlays"
    }
  },
  "$defs": {
    "templateString": {
      "type": "string",
      "description": "String value. Go-template expressions and values#/path fragments are accepted by SwarmCP where documented."
    },
    "scalar": {
      "description": "Scalar value accepted in user-authored config. Prefer strings for Docker labels/env values.",
      "type": ["string", "number", "integer", "boolean", "null"]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "Remote source repository URL."
        },
        "ref": {
          "type": "string",
          "description": "Remote source ref, tag, branch, or commit SHA."
        },
        "path": {
          "type": "string",
          "description": "Path within the local project or fetched source tree."
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "Remote source repository URL."
        },
        "ref": {
          "type": "string",
          "description": "Remote source ref, tag, branch, or commit SHA."
        },
        "path": {
          "type": "string",
          "description": "Path within the local project or fetched source tree."
        },
        "overrides_path": {
          "type": "string",
          "description": "Path to source override documents within the fetched source tree."
        }
      }
    },
    "configDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "File path, inline source, template path, or values#/path fragment."
        },
        "target": {
          "type": "string",
          "description": "Target mount path."
        },
        "uid": {
          "type": "string"
        },
        "gid": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "description": "Unix file mode, commonly quoted octal such as \"0444\"."
        }
      }
    },
    "secretDef": {
      "$ref": "#/$defs/configDef"
    },
    "configRef": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "target": {
              "type": "string"
            },
            "uid": {
              "type": "string"
            },
            "gid": {
              "type": "string"
            },
            "mode": {
              "type": "string"
            }
          }
        }
      ]
    },
    "secretRef": {
      "$ref": "#/$defs/configRef"
    },
    "configDefsOrRefs": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/configDef"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/configRef"
          }
        }
      ]
    },
    "secretDefsOrRefs": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/secretDef"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/secretRef"
          }
        }
      ]
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name used for stack naming and labels."
        },
        "partitions": {
          "$ref": "#/$defs/stringArray",
          "description": "Partition names. '_' is reserved for shared-stack internals."
        },
        "deployments": {
          "$ref": "#/$defs/stringArray",
          "description": "Known deployment names."
        },
        "deployment": {
          "type": "string",
          "description": "Default deployment selection."
        },
        "contexts": {
          "type": "object",
          "description": "Docker context or endpoint by deployment name.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "deployment_targets": {
          "type": "object",
          "description": "Node targeting policy by deployment name.",
          "additionalProperties": {
            "$ref": "#/$defs/deploymentTarget"
          }
        },
        "release_policies": {
          "type": "object",
          "description": "Project/team release version policies used when generating concrete release manifests.",
          "additionalProperties": {
            "$ref": "#/$defs/releasePolicy"
          }
        },
        "defaults": {
          "$ref": "#/$defs/projectDefaults"
        },
        "restart_policy": {
          "$ref": "#/$defs/restartPolicy"
        },
        "update_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "rollback_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "preserve_unused_resources": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of old managed resource versions to preserve."
        },
        "nodes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/node"
          }
        },
        "sources": {
          "$ref": "#/$defs/source"
        },
        "configs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/configDef"
          }
        },
        "secrets": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/secretDef"
          }
        },
        "secrets_engine": {
          "$ref": "#/$defs/secretsEngine"
        }
      }
    },
    "releasePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "$ref": "#/$defs/releaseVersionPolicy"
        }
      }
    },
    "releaseVersionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preset": {
          "type": "string",
          "enum": [
            "semver",
            "semver_prerelease",
            "calver",
            "calver_sequence",
            "branch_calver_sequence",
            "deployment_stack_calver_sequence",
            "semver_calver_build"
          ],
          "description": "Named release version strategy. Prefer presets for normal authoring."
        },
        "scheme": {
          "type": "string",
          "enum": ["template"],
          "description": "Expanded/custom version strategy."
        },
        "template": {
          "type": "string",
          "description": "Template evaluated over resolved version parameters."
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/versionParameter"
          }
        }
      }
    },
    "versionParameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Parameter source such as input.semver, git.branch, clock.date, target.deployment, target.stack, artifact.<kind>..., or release.sequence."
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "git_ref",
            "semver",
            "semver_prerelease",
            "calver",
            "integer",
            "counter"
          ]
        },
        "format": {
          "type": "string",
          "description": "Format string for dates/calver or optional formatted fragments."
        },
        "normalize": {
          "type": "string",
          "enum": ["slug"]
        },
        "omit_if_empty": {
          "type": "boolean"
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "description": "Zero-padding width for integer/counter values."
        },
        "scope": {
          "type": "array",
          "description": "Counter allocation scope. Required by SwarmCP when type is counter.",
          "items": {
            "type": "string",
            "enum": [
              "global",
              "branch",
              "deployment",
              "partition",
              "stack",
              "calver",
              "semver",
              "artifact_tuple"
            ]
          }
        }
      }
    },
    "projectDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "networks": {
          "$ref": "#/$defs/networkDefaults"
        },
        "volumes": {
          "$ref": "#/$defs/volumeDefaults"
        }
      }
    },
    "networkDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "internal": {
          "type": "string"
        },
        "egress": {
          "type": "string"
        },
        "attachable": {
          "type": "boolean"
        },
        "shared": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "volumeDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "driver": {
          "type": "string"
        },
        "base_path": {
          "type": "string"
        },
        "layout": {
          "type": "string"
        },
        "node_label_key": {
          "type": "string"
        },
        "service_standard": {
          "type": "string"
        },
        "service_target": {
          "type": "string"
        },
        "standards": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/standardMount"
          }
        }
      }
    },
    "standardMount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "readonly": {
          "type": "boolean"
        },
        "requires": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "roles": {
              "$ref": "#/$defs/roles"
            }
          }
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["manager", "worker"]
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roles": {
          "$ref": "#/$defs/roles"
        },
        "labels": {
          "$ref": "#/$defs/stringMap"
        },
        "volumes": {
          "$ref": "#/$defs/stringArray"
        },
        "platform": {
          "$ref": "#/$defs/nodePlatform"
        }
      }
    },
    "nodeSpec": {
      "$ref": "#/$defs/node"
    },
    "nodePlatform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": {
          "type": "string",
          "examples": ["linux"]
        },
        "arch": {
          "type": "string",
          "examples": ["amd64", "arm64"]
        }
      }
    },
    "deploymentTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partitions": {
          "$ref": "#/$defs/stringArray"
        },
        "include": {
          "$ref": "#/$defs/nodeSelector"
        },
        "exclude": {
          "$ref": "#/$defs/nodeSelector"
        },
        "overrides": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/nodeSpec"
          }
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "names": {
          "$ref": "#/$defs/stringArray"
        },
        "labels": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "secretsEngine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["vault", "bao", "openbao"]
        },
        "addr": {
          "type": "string"
        },
        "auth": {
          "$ref": "#/$defs/authConfig"
        },
        "vault": {
          "$ref": "#/$defs/vaultKV"
        }
      }
    },
    "authConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": ["oidc", "approle", "jwt", "kubernetes", "tls"]
        },
        "path": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        }
      }
    },
    "vaultKV": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mount": {
          "type": "string"
        },
        "path_template": {
          "type": "string"
        }
      }
    },
    "inclusionRule": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "deployments": {
          "$ref": "#/$defs/stringArray"
        },
        "partitions": {
          "$ref": "#/$defs/stringArray"
        },
        "stacks": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "restartPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "condition": {
          "type": "string",
          "enum": ["none", "on-failure", "any"]
        },
        "delay": {
          "type": "string"
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "window": {
          "type": "string"
        }
      }
    },
    "updatePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parallelism": {
          "type": "integer",
          "minimum": 0
        },
        "delay": {
          "type": "string"
        },
        "failure_action": {
          "type": "string",
          "enum": ["pause", "continue", "rollback"]
        },
        "monitor": {
          "type": "string"
        },
        "max_failure_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "order": {
          "type": "string",
          "enum": ["stop-first", "start-first"]
        }
      }
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "$ref": "#/$defs/sourceRef"
        },
        "overrides": {
          "type": "object",
          "description": "Local override payload for sourced stack definitions.",
          "additionalProperties": true
        },
        "mode": {
          "type": "string",
          "enum": ["shared", "partitioned"]
        },
        "included_in": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inclusionRule"
          }
        },
        "restart_policy": {
          "$ref": "#/$defs/restartPolicy"
        },
        "update_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "rollback_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "partitions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/stackPartition"
          }
        },
        "overlays": {
          "$ref": "#/$defs/stackOverlays"
        },
        "sources": {
          "$ref": "#/$defs/source"
        },
        "configs": {
          "$ref": "#/$defs/configDefsOrRefs"
        },
        "secrets": {
          "$ref": "#/$defs/secretDefsOrRefs"
        },
        "volumes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/volumeDef"
          }
        },
        "services": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/service"
          }
        }
      }
    },
    "stackPartition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restart_policy": {
          "$ref": "#/$defs/restartPolicy"
        },
        "update_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "rollback_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "sources": {
          "$ref": "#/$defs/source"
        },
        "configs": {
          "$ref": "#/$defs/configDefsOrRefs"
        },
        "secrets": {
          "$ref": "#/$defs/secretDefsOrRefs"
        }
      }
    },
    "volumeDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string"
        },
        "subpath": {
          "type": "string"
        }
      }
    },
    "volumeRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "standard": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "subpath": {
          "type": "string"
        },
        "readonly": {
          "type": "boolean"
        },
        "category": {
          "type": "string"
        }
      }
    },
    "port": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "published": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "protocol": {
          "type": "string",
          "enum": ["tcp", "udp"]
        },
        "mode": {
          "type": "string",
          "enum": ["ingress", "host"]
        }
      }
    },
    "serviceNetworkEphemeral": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "internal": {
          "type": "boolean"
        },
        "attachable": {
          "type": "boolean"
        }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "$ref": "#/$defs/sourceRef"
        },
        "overrides": {
          "type": "object",
          "description": "Local override payload for sourced service definitions.",
          "additionalProperties": true
        },
        "image": {
          "type": "string"
        },
        "command": {
          "$ref": "#/$defs/stringArray"
        },
        "args": {
          "$ref": "#/$defs/stringArray"
        },
        "workdir": {
          "type": "string"
        },
        "included_in": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inclusionRule"
          }
        },
        "env": {
          "$ref": "#/$defs/stringMap"
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        },
        "mode": {
          "type": "string",
          "enum": ["replicated", "global"]
        },
        "replicas": {
          "type": "integer",
          "minimum": 0
        },
        "restart_policy": {
          "$ref": "#/$defs/restartPolicy"
        },
        "update_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "rollback_config": {
          "$ref": "#/$defs/updatePolicy"
        },
        "labels": {
          "$ref": "#/$defs/stringMap"
        },
        "placement": {
          "$ref": "#/$defs/placement"
        },
        "healthcheck": {
          "type": "object",
          "additionalProperties": true
        },
        "depends_on": {
          "$ref": "#/$defs/stringArray"
        },
        "egress": {
          "type": "boolean"
        },
        "networks": {
          "$ref": "#/$defs/stringArray"
        },
        "network_ephemeral": {
          "$ref": "#/$defs/serviceNetworkEphemeral"
        },
        "configs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/configRef"
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/secretRef"
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/volumeRef"
          }
        },
        "overlays": {
          "$ref": "#/$defs/serviceOverlays"
        },
        "sources": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "overlays": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deployments": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/overlay"
          }
        },
        "partitions": {
          "$ref": "#/$defs/partitionOverlays"
        }
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project": {
          "$ref": "#/$defs/overlayProject"
        },
        "stacks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/overlayStack"
          }
        }
      }
    },
    "partitionOverlays": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/overlay"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/namedPartitionOverlay"
          }
        }
      ]
    },
    "namedPartitionOverlay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "match"],
      "properties": {
        "name": {
          "type": "string"
        },
        "match": {
          "$ref": "#/$defs/overlayMatch"
        },
        "project": {
          "$ref": "#/$defs/overlayProject"
        },
        "stacks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/overlayStack"
          }
        }
      }
    },
    "overlayMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partition": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["exact", "glob", "regexp"]
                },
                "pattern": {
                  "type": "string"
                }
              }
            }
          ]
        }
      }
    },
    "overlayProject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sealed": {
          "type": "boolean"
        },
        "sources": {
          "$ref": "#/$defs/source"
        },
        "configs": {
          "type": "object",
          "additionalProperties": {
