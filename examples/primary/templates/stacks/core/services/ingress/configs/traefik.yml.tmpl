global:
  checkNewVersion: false
  sendAnonymousUsage: false
api:
  dashboard: true
  debug: true
  insecure: true
log:
  level: {{ config_value "log_level" }}
  filePath: /var/log/traefik-proxy.log
  format: json
  maxAge: 90
  compress: true
accessLog:
  filePath: /var/log/traefik-access.log
  format: json
  fields:
    defaultMode: keep
    headers:
      defaultMode: keep
entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
  websecure:
    address: ":443"
    http:
      middlewares:
        - add-context-id@file
        - inject-geoip@file
      tls:
        certResolver: leresolver
        domains:
{{- range (config_value "domain") }}
          - main: "{{.}}"
            sans:
              - "*.{{.}}"
{{- end }}
    http2:
      maxConcurrentStreams: 250
  ybsql:
    address: ":54333"
providers:
  swarm:
    network: {{ runtime_value "{project}_{stack}" }}
    endpoint: "unix:///var/run/docker.sock"
  file:
    filename: {{ config_ref "dynamic_yml" }}
certificatesResolvers:
  leresolver:
    acme:
      email: "me@{{ config_value_index "domain" 0 }}"
      storage: /etc/traefik/ssl/acme.json
      vaultStorage:
        url: "{{ config_value "vault_url" }}"
        enginePath: "acme/traefik"
        lockOwnerId: "env:VAULT_LOCK_ID"
        tls:
          caBundle: {{ config_ref "ca_chain" }}
          cert: {{ config_ref "vault_client_crt" }}
          key: {{ secret_ref "vault_client_key" }}
        auth:
          certAuth:
            name: "ingress_vault"
      dnsChallenge:
        provider: cloudflare
        resolvers:
          - "8.8.8.8:53"
          - "1.1.1.1:53"
          - "127.0.0.1:53"
