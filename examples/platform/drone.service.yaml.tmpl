image: {{ config_value "drone_image" }}
egress: true
args:
  - "--env-file"
  - {{ secret_ref "drone_env" }}
env:
  DRONE_SERVER_HOST: {{ runtime_value "tasks.{project}_{stack}_drone"}}
  DRONE_SERVER_PORT: ":80"
  DRONE_SERVER_PROTO: "http"
  DRONE_SERVER_PROXY_HOST: {{ printf "drone.%s" (config_value "public_domain") }}
  DRONE_SERVER_PROXY_PROTO: "https"
  DRONE_COOKIE_TIMEOUT: "720h"
  DRONE_GITHUB_CLIENT_ID: {{ config_value "drone_platform_github_client_id" }}
  DRONE_LOGS_DEBUG: "true"
  DRONE_LOGS_TRACE: "true"
  DRONE_LOGS_PRETTY: "true"
  DRONE_CRON_DISABLED: "false"
  DRONE_DATABASE_DRIVER: "sqlite3"
  DRONE_USER_FILTER: {{ config_value "drone_user_filter" }}
  DRONE_USER_CREATE: {{ config_value "drone_create_users" }}
  DRONE_REGISTRATION_CLOSED: "true"
replicas: 1
labels:
  traefik.enable: "true"
  traefik.http.routers.drone.entrypoints: "websecure"
  traefik.http.routers.drone.rule: {{ printf "Host(`drone.%s`)" (config_value "public_domain") }}
  traefik.http.routers.drone.tls: "true"
  traefik.http.routers.drone.service: "drone"
  traefik.http.services.drone.loadbalancer.server.port: 80
  traefik.http.routers.drone-internal.entrypoints: "websecure"
  traefik.http.routers.drone-internal.rule: {{ printf "Host(`drone.%s`)" (config_value "internal_domain") }}
  traefik.http.routers.drone-internal.tls: "true"
  traefik.http.routers.drone-internal.service: "drone"
  traefik.http.services.drone-internal.loadbalancer.server.port: 80
  traefik.swarm.network: {{ runtime_value "{networks_shared}" }}
volumes:
  - standard: persist
    target: /data
secrets:
  - name: drone_env
    source: templates/stacks/tools/services/drone/secrets/drone.env.tmpl

