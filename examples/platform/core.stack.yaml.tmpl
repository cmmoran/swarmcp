mode: shared
services:
  agent:
    image: {{ config_value "portainer_agent_image" }}
    egress: true
    env:
      AGENT_CLUSTER_ADDR: tasks.agent
      LOG_LEVEL: DEBUG
    ports:
      - target: 9001
        published: 9001
        protocol: tcp
        mode: host
    volumes:
      - standard: docker_sock
      - standard: docker_volumes
      - standard: host
    mode: global
    placement:
      constraints:
        - node.platform.os == linux
    labels:
      traefik.enable: "false"
  portainer:
    image: {{ config_value "portainer_image" }}
    args:
      - -H
      - tcp://tasks.agent:9001
      - --tlsskipverify
    egress: true
    volumes:
      - standard: persist
        target: /data
      - standard: docker_sock
    replicas: 1
    labels:
      traefik.enable: "true"
      traefik.http.routers.portainer.entrypoints: websecure
      traefik.http.routers.portainer.rule: {{ printf "Host(`m.%s`)" (config_value "internal_domain") }}
      traefik.http.routers.portainer.service: portainer
      traefik.http.routers.portainer.tls: "true"
      traefik.http.services.portainer.loadbalancer.server.port: "9000"
      traefik.swarm.network: {{ runtime_value "{networks_shared}" }}
  ingress:
    image: {{ config_value "traefik_image" }}
    egress: true
    mode: global
    env:
      AWS_HOSTED_ZONE_ID: {{ config_value "aws_hosted_zone_id" }}
      AWS_REGION: {{ config_value "aws_region" }}
      AWS_SHARED_CREDENTIALS_FILE: {{ secret_ref "aws_shared_credentials" }}
      VAULT_LOCK_ID: {{ escape_template "{{ .Service.Name }}.{{ .Task.Slot }}" }}
    labels:
      traefik.enable: "false"
      traefik.swarm.lbswarm: "true"
    volumes:
      - source: /var/log/traefik
        target: /var/log
        readonly: false
      - standard: docker_sock
      - standard: persist
        target: /etc/geoip
    ports:
      - target: 80
        published: 80
        mode: host
      - target: 443
        published: 443
        mode: host
      - target: 8080
        published: 8080
        mode: host
    configs:
      - name: vault_client_crt
        source: templates/stacks/core/services/ingress/configs/vault_client.crt
      - name: traefik_yml
        source: templates/stacks/core/services/ingress/configs/traefik.yml.tmpl
        target: /etc/traefik/traefik.yml
      - name: dynamic_yml
        source: templates/stacks/core/services/ingress/configs/dynamic.yml.tmpl
        target: /etc/traefik/dynamic.yml
    secrets:
      - name: vault_client_key
        target: /run/secrets/vault_client.key
      - name: aws_shared_credentials
        source: templates/stacks/core/services/ingress/secrets/aws_shared_credentials.tmpl
