traefik_image: "traefik:v3.6"
log_level: "info"
acme_email: "ops@example.com"
acme_vault_path: "/edge/etc/traefik/ssl/acme.json"
vault_url: "https://vault.example.com:8200"
aws_region: "us-east-1"
aws_hosted_zone_id: "Z123456EXAMPLE"
trusted_loadbalancers:
  - "10.0.0.0/8"

edge_cert_main: "*.sentinelsyn.com"
edge_cert_sans:
  - "*.dev.sentinelsyn.com"
  - "*.qa.sentinelsyn.com"
  - "*.demo.sentinelsyn.com"
  - "*.core.sentinelsyn.com"

edge_sso_routes:
  - name: edge-sso-dev
    host_suffix: "dev.sentinelsyn.com"
  - name: edge-sso-qa
    host_suffix: "qa.sentinelsyn.com"
  - name: edge-sso-demo
    host_suffix: "demo.sentinelsyn.com"

edge_participant_routes:
  - name: edge-participant-core
    host_suffix: "core.sentinelsyn.com"

sso_server_name: "ingress.sso"
sso_client_common_name: "edge-to-sso"
participant_server_name: "ingress.participant"
participant_client_common_name: "edge-to-participant"

sso_internal_domain: "dev.sentinelsyn.com"
participant_internal_domain: "core.sentinelsyn.com"
