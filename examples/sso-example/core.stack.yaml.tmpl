mode: shared
services:
  ingress:
    image: {{ config_value "traefik_image" }}
    egress: true
    mode: global
    labels:
      traefik.enable: "false"
      traefik.swarm.lbswarm: "true"
    volumes:
      - source: /var/log/traefik
        target: /var/log
        readonly: false
      - standard: docker_sock
    ports:
      - target: 443
        published: 443
        mode: host
    configs:
      - name: traefik_yml
        source: templates/stacks/core/services/ingress/configs/traefik.yml.tmpl
        target: /etc/traefik/traefik.yml
      - name: dynamic_yml
        source: templates/stacks/core/services/ingress/configs/dynamic.yml.tmpl
        target: /etc/traefik/dynamic.yml
      - name: edge_ca
      - name: ingress_crt
        source: templates/stacks/core/services/ingress/configs/ingress.crt
        target: /etc/traefik/ingress.crt
    secrets:
      - name: ingress_key
        source: templates/stacks/core/services/ingress/secrets/ingress.key
        target: /run/secrets/ingress.key
